<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/css text/javascript application/javascript application/json application/xml image/svg+xml
</IfModule>

AddType image/webp .webp

<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/css "access plus 1 year"
    ExpiresByType application/javascript "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"
    ExpiresByType text/html "access plus 0 seconds"
</IfModule>

<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=()"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always unset X-Powered-By

    Header append Vary Accept env=accept
    <FilesMatch "\.(css|js|jpg|jpeg|png|svg|webp|woff2)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
    <FilesMatch "\.(html|php)$">
        Header set Cache-Control "no-store, no-cache, must-revalidate, max-age=0"
        Header set Pragma "no-cache"
        Header set Expires "0"
    </FilesMatch>
</IfModule>

<FilesMatch "(^\.|db-config\.php$|config\.php$|database\.sql$|composer\.(json|lock)$|package(-lock)?\.json$)">
    Require all denied
</FilesMatch>

<IfModule mod_rewrite.c>
    RewriteEngine On

    RewriteRule ^data(?:/|$) - [F,L,NC]

    # Canonical public URLs: redirect browser requests for legacy PHP pages.
    RewriteCond %{REQUEST_METHOD} ^(?:GET|HEAD)$ [NC]
    RewriteCond %{THE_REQUEST} \s/+[^\s?]*index\.php(?:[?\s]) [NC]
    RewriteRule ^index\.php$ ./ [R=301,L,NE]

    RewriteCond %{REQUEST_METHOD} ^(?:GET|HEAD)$ [NC]
    RewriteCond %{THE_REQUEST} \s/+[^\s?]*(?:el-estudio|servicios|servicio-proyectos|obra-viva|obras|blog|contacto|trabaja-con-nosotros|newsletter-gracias)\.php(?:[?\s]) [NC]
    RewriteRule ^(el-estudio|servicios|servicio-proyectos|obra-viva|obras|blog|contacto|trabaja-con-nosotros|newsletter-gracias)\.php$ $1 [R=301,L,NE]

    RewriteCond %{REQUEST_METHOD} ^(?:GET|HEAD)$ [NC]
    RewriteCond %{THE_REQUEST} \s/+[^\s?]*(?:como-anticipar-decisiones-criticas-antes-de-iniciar-una-obra|documentacion-ejecutiva-el-mapa-que-evita-errores-en-obra|estrategias-ambientales-que-elevan-el-valor-del-proyecto)\.php(?:[?\s]) [NC]
    RewriteRule ^(?:como-anticipar-decisiones-criticas-antes-de-iniciar-una-obra|documentacion-ejecutiva-el-mapa-que-evita-errores-en-obra|estrategias-ambientales-que-elevan-el-valor-del-proyecto)\.php$ blog [R=301,L,NE]

    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(.+)/$ $1 [R=301,L]

    RewriteCond %{HTTP_ACCEPT} image/webp
    RewriteCond %{REQUEST_FILENAME} ^(.+)\.(jpe?g|png)$ [NC]
    RewriteCond %1.webp -f
    RewriteRule ^(.+)\.(jpe?g|png)$ $1.webp [T=image/webp,E=accept:1,L]

    # Friendly public pages.
    RewriteRule ^el-estudio$ el-estudio.php [L,QSA]
    RewriteRule ^servicios$ servicios.php [L,QSA]
    RewriteRule ^servicio-proyectos$ servicio-proyectos.php [L,QSA]
    RewriteRule ^obra-viva$ obra-viva.php [L,QSA]
    RewriteRule ^obras$ obras.php [L,QSA]
    RewriteRule ^blog$ blog.php [L,QSA]
    RewriteRule ^contacto$ contacto.php [L,QSA]
    RewriteRule ^trabaja-con-nosotros$ trabaja-con-nosotros.php [L,QSA]
    RewriteRule ^newsletter-gracias$ newsletter-gracias.php [L,QSA]
    RewriteRule ^articulos/([a-z0-9-]+)$ articulo.php?slug=$1 [L,QSA]
    RewriteRule ^obras/([a-z0-9-]+)$ obra.php?slug=$1 [L,QSA]
</IfModule>
